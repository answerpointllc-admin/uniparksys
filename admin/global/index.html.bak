<div><label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:4px">Default Currency</label><select style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;font-family:'DM Sans';background:var(--bg)"><option>USD ($)</option><option>EUR (€)</option><option>GBP (£)</option></select></div>
<div><label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:4px">Default Timezone</label><select style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;font-family:'DM Sans';background:var(--bg)"><option>America/New_York (EST)</option><option>America/Chicago (CST)</option><option>America/Denver (MST)</option><option>America/Los_Angeles (PST)</option></select></div>
<div><label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:4px">Trial Duration (days)</label><input type="number" style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;font-family:'DM Sans'" value="60"></div>
<div style="margin-top:4px"><button class="tb-btn" style="font-size:12px">Save Settings</button></div>
</div>
</div>
<div class="card">
<div class="card-header"><h3>Integrations</h3></div>
<div style="display:flex;flex-direction:column;gap:10px">
<div style="display:flex;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--border);border-radius:8px"><div class="flex"><div style="font-size:20px">💳</div><div><div style="font-size:13px;font-weight:600">Stripe</div><div style="font-size:11px;color:var(--muted)">Payment processing</div></div></div><span class="pill pill-green">Connected</span></div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--border);border-radius:8px"><div class="flex"><div style="font-size:20px">📡</div><div><div style="font-size:13px;font-weight:600">IoT Gateway</div><div style="font-size:11px;color:var(--muted)">Sensor data ingestion</div></div></div><span class="pill pill-green">Connected</span></div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--border);border-radius:8px"><div class="flex"><div style="font-size:20px">📧</div><div><div style="font-size:13px;font-weight:600">SendGrid</div><div style="font-size:11px;color:var(--muted)">Transactional email</div></div></div><span class="pill pill-green">Connected</span></div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--border);border-radius:8px"><div class="flex"><div style="font-size:20px">📊</div><div><div style="font-size:13px;font-weight:600">Google Analytics</div><div style="font-size:11px;color:var(--muted)">Usage tracking</div></div></div><span class="pill pill-amber">Not Configured</span></div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--border);border-radius:8px"><div class="flex"><div style="font-size:20px">🗺️</div><div><div style="font-size:13px;font-weight:600">Google Maps API</div><div style="font-size:11px;color:var(--muted)">Location services</div></div></div><span class="pill pill-green">Connected</span></div>
</div>
</div>
</div>
</div>

<!-- STATEMENTS -->
<div class="panel" id="p-statements">
<div class="grid g2" style="margin-bottom:16px">
<div class="card">
<div class="card-header"><h3>Active Statement</h3><span class="pill pill-green" style="font-size:11px">Live on Homepage</span></div>
<div style="padding:20px;background:linear-gradient(135deg,var(--navy),#243B5E);border-radius:10px;text-align:center;margin-bottom:14px">
<div style="font-size:20px;font-weight:700;color:#fff;line-height:1.4;font-style:italic;font-family:'Montserrat'" id="activeQuote">"Parking operations, reimagined."</div>
<div style="font-size:11px;color:rgba(255,255,255,.5);margin-top:8px">Active since Jan 1, 2026 · Expires Mar 31, 2026</div>
</div>
<div style="font-size:12px;color:var(--muted)">Statements rotate automatically every quarter. The next rotation is <strong>April 1, 2026</strong>.</div>
</div>
<div class="card">
<div class="card-header"><h3>Next Statement (Queued)</h3><span class="pill pill-blue" style="font-size:11px">Starts Apr 1</span></div>
<div style="padding:20px;background:var(--bg);border:2px dashed var(--border);border-radius:10px;text-align:center;margin-bottom:14px">
<div style="font-size:20px;font-weight:700;color:var(--navy);line-height:1.4;font-style:italic;font-family:'Montserrat'" id="nextQuote">"Where will you be, if you don't know where you are?"</div>
<div style="font-size:11px;color:var(--muted);margin-top:8px">Scheduled: Apr 1 – Jun 30, 2026</div>
</div>
<div style="display:flex;gap:8px"><button class="btn-sm" onclick="previewStmt()">👁️ Preview on Site</button><button class="btn-sm" style="color:var(--red)">Remove from Queue</button></div>
</div>
</div>
<div class="card" style="margin-bottom:16px">
<div class="card-header"><h3>Add New Statement</h3></div>
<div style="display:flex;gap:12px;align-items:flex-end">
<div style="flex:1"><label class="label">Statement Text</label><input class="tb-search" id="newStmt" placeholder='e.g. "Every spot counts. Every second matters."' style="width:100%;padding:10px 14px"></div>
<div style="width:150px"><label class="label">Quarter Start</label><select class="tb-search" id="newQtr" style="width:100%;padding:10px 14px;background:var(--bg)"><option>Q3 2026 (Jul 1)</option><option>Q4 2026 (Oct 1)</option><option>Q1 2027 (Jan 1)</option><option>Q2 2027 (Apr 1)</option></select></div>
<button class="tb-btn" onclick="addStmt()" style="height:42px">+ Add to Queue</button>
</div>
</div>
<div class="card">
<div class="card-header"><h3>Statement History</h3><button class="btn-sm">Export</button></div>
<table class="tbl"><thead><tr><th>#</th><th>Statement</th><th>Quarter</th><th>Status</th><th>Added</th><th>Actions</th></tr></thead><tbody id="stmtTable">
<tr><td>1</td><td style="font-style:italic">"Parking operations, reimagined."</td><td>Q1 2026 (Jan–Mar)</td><td><span class="pill pill-green">Active</span></td><td class="mono">Dec 15, 2025</td><td><button class="btn-sm">Edit</button></td></tr>
<tr><td>2</td><td style="font-style:italic">"Where will you be, if you don't know where you are?"</td><td>Q2 2026 (Apr–Jun)</td><td><span class="pill pill-blue">Queued</span></td><td class="mono">Feb 24, 2026</td><td><button class="btn-sm">Edit</button> <button class="btn-sm" style="color:var(--red)">Delete</button></td></tr>
</tbody></table>
</div>
<div class="card" style="margin-top:16px">
<div class="card-header"><h3>Rotation Settings</h3></div>
<div class="grid g3" style="gap:12px">
<div style="padding:12px;background:var(--bg);border-radius:8px"><strong style="font-size:12px">Rotation Cycle</strong><div style="font-size:12px;color:var(--muted);margin-top:4px">Every 3 months (quarterly)</div></div>
<div style="padding:12px;background:var(--bg);border-radius:8px"><strong style="font-size:12px">Display Location</strong><div style="font-size:12px;color:var(--muted);margin-top:4px">Homepage hero subtitle</div></div>
<div style="padding:12px;background:var(--bg);border-radius:8px"><strong style="font-size:12px">Fallback</strong><div style="font-size:12px;color:var(--muted);margin-top:4px">If no queued statement, repeat last active</div></div>
</div>
</div>
</div>

</div><!-- /content -->
</div><!-- /main -->

<script>
function showPanel(id){
document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
document.getElementById('p-'+id).classList.add('active');
document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('active'));
event.currentTarget.classList.add('active');
const titles={dashboard:'Dashboard',clients:'Clients',facilities:'Facilities',users:'Users',reservations:'Reservations',onboarding:'Client Onboarding',billing:'Billing & Revenue',provisioning:'Provisioning Tools',analytics:'Platform Analytics',audit:'Audit Log',config:'Configuration',statements:'Homepage Statements'};
document.getElementById('pageTitle').textContent=titles[id]||id;
}
function switchInner(el){el.parentElement.querySelectorAll('.inner-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active')}
let stmtCount=2;
function addStmt(){
const txt=document.getElementById('newStmt').value.trim();
if(!txt)return;
const qtr=document.getElementById('newQtr').value;
stmtCount++;
const row=document.createElement('tr');
row.innerHTML='<td>'+stmtCount+'</td><td style="font-style:italic">"'+txt+'"</td><td>'+qtr+'</td><td><span class="pill pill-blue">Queued</span></td><td class="mono">Feb 24, 2026</td><td><button class="btn-sm">Edit</button> <button class="btn-sm" style="color:var(--red)">Delete</button></td>';
document.getElementById('stmtTable').appendChild(row);
document.getElementById('newStmt').value='';
}
function previewStmt(){alert('Preview: Opens homepage with the queued statement overlaid. (In production, this would render a live preview.)')}
</script>
</body>
</html>
