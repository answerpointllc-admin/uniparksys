<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 36 36'><path d='M18 2L32 9V23L18 34L4 23V9Z' fill='%231B2A4A'/><text x='18' y='20' text-anchor='middle' font-family='sans-serif' font-weight='800' font-size='12' fill='white'>P</text><circle cx='18' cy='29.5' r='2.5' fill='%23E8883E'/></svg>">
<title>UniPark — Global Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#F4F6F8;--sidebar:#1B2A4A;--sidebar-h:#243B5E;--card:#FFF;
--navy:#1B2A4A;--teal:#3BA0B5;--org:#E8883E;--gold:#D4A843;
--red:#DC2626;--red-l:#FEE2E2;--green:#22C55E;--green-l:#DCFCE7;
--blue:#3B82F6;--purple:#8B5CF6;--amber:#F59E0B;
--text:#1B2A4A;--muted:#64748B;--light:#94A3B8;--border:#E2E8F0;
--radius:10px;--shadow:0 1px 3px rgba(0,0,0,.06),0 2px 8px rgba(0,0,0,.04);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;overflow-x:hidden}
h1,h2,h3,h4,h5{font-family:'Montserrat',sans-serif}
/* SIDEBAR */
.sb{width:240px;margin-top:36px;background:var(--sidebar);color:#fff;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:50;transition:.3s}
.sb-brand{padding:18px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,.08)}
.sb-brand svg{width:32px;height:32px;flex-shrink:0}
.sb-brand-text{display:flex;flex-direction:column}
.sb-brand-name{font-family:'Montserrat';font-weight:800;font-size:16px}
.sb-brand-badge{font-size:8px;font-weight:700;background:var(--red);color:#fff;padding:2px 6px;border-radius:3px;letter-spacing:.8px;width:fit-content;margin-top:2px}
.sb-nav{flex:1;padding:12px 8px;overflow-y:auto}
.sb-section{font-size:9px;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;padding:12px 12px 6px}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;font-size:13px;font-weight:500;color:rgba(255,255,255,.6);cursor:pointer;transition:.15s;margin-bottom:1px}
.sb-item:hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.9)}
.sb-item.active{background:rgba(59,160,181,.15);color:var(--teal)}
.sb-item .icon{width:18px;text-align:center;font-size:14px;flex-shrink:0}
.sb-item .badge{margin-left:auto;font-size:10px;font-weight:700;background:var(--red);color:#fff;padding:1px 6px;border-radius:10px;min-width:18px;text-align:center}
.sb-footer{padding:12px 16px;border-top:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:10px}
.sb-avatar{width:32px;height:32px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;flex-shrink:0}
.sb-user{font-size:12px;font-weight:600;color:rgba(255,255,255,.8)}.sb-role{font-size:10px;color:rgba(255,255,255,.4)}
/* MAIN */
.main{margin-left:240px;margin-top:36px;flex:1;min-height:100vh}
.topbar{background:var(--card);border-bottom:1px solid var(--border);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40}
.topbar h1{font-size:18px;font-weight:700}
.topbar-actions{display:flex;align-items:center;gap:12px}
.tb-search{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:13px;width:240px;font-family:'DM Sans';outline:none}
.tb-search:focus{border-color:var(--teal)}
.tb-btn{background:var(--teal);color:#fff;border:none;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Montserrat';display:flex;align-items:center;gap:6px;transition:.2s}
.tb-btn:hover{background:#2D8295}
.content{padding:20px 24px}
/* CARDS & GRIDS */
.grid{display:grid;gap:16px}.g2{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr 1fr}.g4{grid-template-columns:1fr 1fr 1fr 1fr}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow)}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-header h3{font-size:14px;font-weight:700}
.card-header .link{font-size:12px;color:var(--teal);font-weight:600;cursor:pointer}
/* STAT CARDS */
.stat{text-align:center;padding:20px 16px}
.stat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:18px}
.si-teal{background:rgba(59,160,181,.1);color:var(--teal)}
.si-org{background:rgba(232,136,62,.1);color:var(--org)}
.si-green{background:rgba(34,197,94,.1);color:var(--green)}
.si-red{background:rgba(220,38,38,.1);color:var(--red)}
.si-blue{background:rgba(59,130,246,.1);color:var(--blue)}
.si-purple{background:rgba(139,92,246,.1);color:var(--purple)}
.si-gold{background:rgba(212,168,67,.1);color:var(--gold)}
.si-amber{background:rgba(245,158,11,.1);color:var(--amber)}
.stat-val{font-family:'Montserrat';font-size:24px;font-weight:800}
.stat-label{font-size:11px;color:var(--muted);margin-top:2px}
.stat-delta{font-size:10px;font-weight:600;margin-top:4px}
.delta-up{color:var(--green)}.delta-down{color:var(--red)}
/* TABLE */
.tbl{width:100%;border-collapse:collapse;font-size:12px}
.tbl th{text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding:8px 10px;border-bottom:2px solid var(--border)}
.tbl td{padding:10px;border-bottom:1px solid var(--border);vertical-align:middle}
.tbl tr:hover{background:rgba(59,160,181,.02)}
.pill{font-size:10px;font-weight:600;padding:3px 10px;border-radius:100px;display:inline-block}
.pill-green{background:var(--green-l);color:#16A34A}
.pill-red{background:var(--red-l);color:var(--red)}
.pill-amber{background:#FEF3C7;color:#D97706}
.pill-blue{background:#DBEAFE;color:#2563EB}
.pill-gray{background:#F1F5F9;color:var(--muted)}
/* TABS (inner) */
.inner-tabs{display:flex;gap:2px;background:var(--bg);border-radius:8px;padding:3px;margin-bottom:16px;border:1px solid var(--border)}
.inner-tab{padding:7px 14px;font-size:12px;font-weight:600;border-radius:6px;cursor:pointer;color:var(--muted);transition:.15s}
.inner-tab:hover{color:var(--text)}
.inner-tab.active{background:var(--card);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.08)}
/* BAR CHART */
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.bar-label{font-size:11px;width:80px;text-align:right;color:var(--muted);font-weight:500}
.bar-track{flex:1;height:20px;background:var(--bg);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:.6s ease}
.bar-val{font-size:11px;font-weight:700;width:50px}
/* PANEL VISIBILITY */
.panel{display:none}.panel.active{display:block}
/* MISC */
.avatar-sm{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:10px;color:#fff;flex-shrink:0}
.empty{text-align:center;padding:40px;color:var(--muted);font-size:13px}
.mono{font-family:'JetBrains Mono',monospace;font-size:11px}
.sep{height:1px;background:var(--border);margin:16px 0}
.flex{display:flex;align-items:center;gap:8px}
.btn-sm{padding:5px 12px;font-size:11px;font-weight:600;border-radius:6px;border:1px solid var(--border);background:var(--card);cursor:pointer;font-family:'DM Sans';transition:.15s}
.btn-sm:hover{border-color:var(--teal);color:var(--teal)}
.btn-sm-primary{background:var(--teal);color:#fff;border-color:var(--teal)}
.btn-sm-primary:hover{background:#2D8295}
.btn-sm-red{background:var(--red);color:#fff;border-color:var(--red)}
.btn-sm-red:hover{background:#B91C1C}
@media(max-width:900px){.sb{display:none}.main{margin-left:0}}
</style>
<script src="/app/js/apms-error-handler.js"></script>
<script>APMSErrorHandler.init({product:'unipark',module:'global'});</script>
</head>
<body>
<!-- CROSS NAV -->
<nav id="xnav" style="background:#0F1A2E;padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:36px;position:fixed;top:0;left:0;right:0;z-index:9999;font-family:'DM Sans',sans-serif">
<div style="display:flex;align-items:center;gap:10px">
<a href="/app/" style="color:rgba(255,255,255,.6);font-size:11px;text-decoration:none;font-weight:600">← Dashboard</a>
<span style="color:rgba(255,255,255,.1)">|</span>
<a href="/admin/global/" class="xn" style="color:rgba(255,255,255,.45);font-size:11px;text-decoration:none;padding:3px 8px;border-radius:4px;transition:.15s" style="color:#fff!important;background:rgba(59,160,181,.2);font-size:11px;text-decoration:none;padding:3px 8px;border-radius:4px">Global Admin</a>
<a href="/admin/local/" class="xn" style="color:rgba(255,255,255,.45);font-size:11px;text-decoration:none;padding:3px 8px;border-radius:4px;transition:.15s">Local Admin</a>
<a href="/portal/consumer/" class="xn" style="color:rgba(255,255,255,.45);font-size:11px;text-decoration:none;padding:3px 8px;border-radius:4px;transition:.15s">Consumer</a>
<a href="/portal/client/" class="xn" style="color:rgba(255,255,255,.45);font-size:11px;text-decoration:none;padding:3px 8px;border-radius:4px;transition:.15s">Client</a>
</div>
<a href="/login/" style="color:rgba(255,255,255,.35);font-size:10px;text-decoration:none;font-weight:500">Sign Out</a>
</nav>
<style>#xnav .xn:hover{color:#fff!important;background:rgba(255,255,255,.08)}</style>


<!-- SIDEBAR -->
<aside class="sb">
<div class="sb-brand">
<svg viewBox="0 0 36 36" fill="none"><path d="M18 2L32 9V23L18 34L4 23V9L18 2Z" fill="#1B2A4A" stroke="#3BA0B5" stroke-width="1.2"/><text x="18" y="20" text-anchor="middle" font-family="Montserrat" font-weight="800" font-size="12" fill="#FFF">P</text><circle cx="18" cy="29.5" r="2.5" fill="#E8883E" stroke="#1B2A4A" stroke-width="1"/></svg>
<div class="sb-brand-text"><span class="sb-brand-name">UniPark</span><span class="sb-brand-badge">GLOBAL ADMIN</span></div>
</div>
<nav class="sb-nav">
<div class="sb-section">Overview</div>
<div class="sb-item active" onclick="showPanel('dashboard')"><span class="icon">📊</span> Dashboard</div>
<div class="sb-section">Management</div>
<div class="sb-item" onclick="showPanel('clients')"><span class="icon">🏢</span> Clients <span class="badge">847</span></div>
<div class="sb-item" onclick="showPanel('facilities')"><span class="icon">🅿️</span> Facilities</div>
<div class="sb-item" onclick="showPanel('users')"><span class="icon">👥</span> Users</div>
<div class="sb-item" onclick="showPanel('reservations')"><span class="icon">📋</span> Reservations <span class="badge">24</span></div>
<div class="sb-section">Operations</div>
<div class="sb-item" onclick="showPanel('onboarding')"><span class="icon">🚀</span> Onboarding</div>
<div class="sb-item" onclick="showPanel('billing')"><span class="icon">💰</span> Billing</div>
<div class="sb-item" onclick="showPanel('provisioning')"><span class="icon">⚙️</span> Provisioning</div>
<div class="sb-section">System</div>
<div class="sb-item" onclick="showPanel('analytics')"><span class="icon">📈</span> Analytics</div>
<div class="sb-item" onclick="showPanel('audit')"><span class="icon">🔒</span> Audit Log</div>
<div class="sb-item" onclick="showPanel('config')"><span class="icon">🔧</span> Configuration</div>
<div class="sb-section">Content</div>
<div class="sb-item" onclick="showPanel('statements')"><span class="icon">💬</span> Statements</div>
</nav>
<div class="sb-footer">
<div class="sb-avatar" style="background:var(--red)">GM</div>
<div><div class="sb-user">Glenn McGregor</div><div class="sb-role">Super Administrator</div></div>
</div>
</aside>

<!-- MAIN -->
<div class="main">
<div class="topbar">
<h1 id="pageTitle">Dashboard</h1>
<div class="topbar-actions">
<input class="tb-search" placeholder="Search clients, facilities, users...">
<button class="tb-btn">+ New Client</button>
</div>
</div>
<div class="content">

<!-- DASHBOARD -->
<div class="panel active" id="p-dashboard">
<div class="grid g4" style="margin-bottom:16px">
<div class="card stat"><div class="stat-icon si-teal">🏢</div><div class="stat-val">847</div><div class="stat-label">Active Clients</div><div class="stat-delta delta-up">↑ 12 this month</div></div>
<div class="card stat"><div class="stat-icon si-org">🅿️</div><div class="stat-val">42,380</div><div class="stat-label">Total Spots</div><div class="stat-delta delta-up">↑ 1,240 added</div></div>
<div class="card stat"><div class="stat-icon si-green">💲</div><div class="stat-val">$2.4M</div><div class="stat-label">MRR</div><div class="stat-delta delta-up">↑ 8.3% MoM</div></div>
<div class="card stat"><div class="stat-icon si-blue">📋</div><div class="stat-val">156K</div><div class="stat-label">Reservations (30d)</div><div class="stat-delta delta-up">↑ 14.2%</div></div>
</div>
<div class="grid g2" style="margin-bottom:16px">
<div class="card">
<div class="card-header"><h3>Revenue by Tier (Monthly)</h3><span class="link">Export</span></div>
<div class="bar-row"><span class="bar-label">Enterprise</span><div class="bar-track"><div class="bar-fill" style="width:78%;background:var(--navy)"></div></div><span class="bar-val">$1.87M</span></div>
<div class="bar-row"><span class="bar-label">Professional</span><div class="bar-track"><div class="bar-fill" style="width:45%;background:var(--teal)"></div></div><span class="bar-val">$420K</span></div>
<div class="bar-row"><span class="bar-label">Starter</span><div class="bar-track"><div class="bar-fill" style="width:15%;background:var(--org)"></div></div><span class="bar-val">$110K</span></div>
<div class="bar-row"><span class="bar-label">Trial</span><div class="bar-track"><div class="bar-fill" style="width:4%;background:var(--light)"></div></div><span class="bar-val">$0</span></div>
</div>
<div class="card">
<div class="card-header"><h3>Occupancy by Region</h3><span class="link">View Map</span></div>
<div class="bar-row"><span class="bar-label">Northeast</span><div class="bar-track"><div class="bar-fill" style="width:89%;background:var(--green)"></div></div><span class="bar-val">89%</span></div>
<div class="bar-row"><span class="bar-label">Midwest</span><div class="bar-track"><div class="bar-fill" style="width:76%;background:var(--teal)"></div></div><span class="bar-val">76%</span></div>
<div class="bar-row"><span class="bar-label">Southeast</span><div class="bar-track"><div class="bar-fill" style="width:72%;background:var(--teal)"></div></div><span class="bar-val">72%</span></div>
<div class="bar-row"><span class="bar-label">West</span><div class="bar-track"><div class="bar-fill" style="width:68%;background:var(--org)"></div></div><span class="bar-val">68%</span></div>
<div class="bar-row"><span class="bar-label">Southwest</span><div class="bar-track"><div class="bar-fill" style="width:61%;background:var(--amber)"></div></div><span class="bar-val">61%</span></div>
</div>
</div>
<div class="grid g2">
<div class="card">
<div class="card-header"><h3>Recent Onboarding</h3><span class="link">View All</span></div>
<table class="tbl"><thead><tr><th>Client</th><th>Tier</th><th>Stage</th><th>Started</th></tr></thead><tbody>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--teal)">MP</div> Metro Parking Group</td><td><span class="pill pill-blue">Enterprise</span></td><td><span class="pill pill-amber">Config</span></td><td>Feb 20</td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--org)">LC</div> Lakewood Centers</td><td><span class="pill pill-green">Professional</span></td><td><span class="pill pill-green">Live</span></td><td>Feb 18</td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--navy)">PR</div> ParkRight Solutions</td><td><span class="pill pill-green">Professional</span></td><td><span class="pill pill-amber">Testing</span></td><td>Feb 15</td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--purple)">DP</div> Downtown Parking LLC</td><td><span class="pill pill-gray">Starter</span></td><td><span class="pill pill-blue">Provisioning</span></td><td>Feb 22</td></tr>
</tbody></table>
</div>
<div class="card">
<div class="card-header"><h3>System Health</h3><span class="link">Details</span></div>
<table class="tbl"><thead><tr><th>Service</th><th>Status</th><th>Latency</th><th>Uptime</th></tr></thead><tbody>
<tr><td>API Gateway</td><td><span class="pill pill-green">Healthy</span></td><td class="mono">12ms</td><td>99.99%</td></tr>
<tr><td>Reservation Engine</td><td><span class="pill pill-green">Healthy</span></td><td class="mono">8ms</td><td>99.98%</td></tr>
<tr><td>Payment Processor</td><td><span class="pill pill-green">Healthy</span></td><td class="mono">45ms</td><td>99.97%</td></tr>
<tr><td>IoT Sensor Hub</td><td><span class="pill pill-amber">Degraded</span></td><td class="mono">120ms</td><td>99.82%</td></tr>
<tr><td>Analytics Pipeline</td><td><span class="pill pill-green">Healthy</span></td><td class="mono">34ms</td><td>99.95%</td></tr>
</tbody></table>
</div>
</div>
</div>

<!-- CLIENTS -->
<div class="panel" id="p-clients">
<div class="inner-tabs"><div class="inner-tab active" onclick="switchInner(this)">All Clients</div><div class="inner-tab" onclick="switchInner(this)">Enterprise</div><div class="inner-tab" onclick="switchInner(this)">Professional</div><div class="inner-tab" onclick="switchInner(this)">Starter</div><div class="inner-tab" onclick="switchInner(this)">Trial</div></div>
<div class="card">
<table class="tbl"><thead><tr><th>Client</th><th>Tier</th><th>Facilities</th><th>Spots</th><th>MRR</th><th>Occupancy</th><th>Status</th><th>Actions</th></tr></thead><tbody>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--navy)">MP</div> Metro Parking Group</td><td><span class="pill pill-blue">Enterprise</span></td><td>42</td><td>8,420</td><td>$34,800</td><td>89%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--teal)">CC</div> CityCenter Garages</td><td><span class="pill pill-blue">Enterprise</span></td><td>28</td><td>6,100</td><td>$28,500</td><td>84%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--org)">AP</div> AirPark National</td><td><span class="pill pill-blue">Enterprise</span></td><td>35</td><td>12,000</td><td>$42,000</td><td>91%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--green)">LC</div> Lakewood Centers</td><td><span class="pill pill-green">Professional</span></td><td>8</td><td>2,400</td><td>$799</td><td>76%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--purple)">PR</div> ParkRight Solutions</td><td><span class="pill pill-green">Professional</span></td><td>12</td><td>3,100</td><td>$799</td><td>72%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--amber)">DP</div> Downtown Parking LLC</td><td><span class="pill pill-gray">Starter</span></td><td>2</td><td>340</td><td>$299</td><td>68%</td><td><span class="pill pill-green">Active</span></td><td><button class="btn-sm">Manage</button></td></tr>
<tr><td class="flex"><div class="avatar-sm" style="background:var(--red)">NP</div> NovaPark Inc</td><td><span class="pill pill-amber">Trial</span></td><td>1</td><td>120</td><td>$0</td><td>45%</td><td><span class="pill pill-amber">Trial (18d left)</span></td><td><button class="btn-sm">Manage</button></td></tr>
</tbody></table>
</div>
</div>

<!-- FACILITIES -->
<div class="panel" id="p-facilities">
<div class="inner-tabs"><div class="inner-tab active" onclick="switchInner(this)">All Facilities</div><div class="inner-tab" onclick="switchInner(this)">Garages</div><div class="inner-tab" onclick="switchInner(this)">Surface Lots</div><div class="inner-tab" onclick="switchInner(this)">Valet</div></div>
